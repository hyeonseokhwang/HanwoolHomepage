<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>한울영성개발원 — E안: 하이브리드 최적안 (CEO 추천)</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;600;700&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
<noscript><link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;600;700&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet"></noscript>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --charcoal:#1C1C1C;--charcoal-mid:#2D2D2D;
  --cream:#FAF8F4;--cream-dark:#F0EDE7;
  --gold:#C9A96E;--gold-deep:#A8883F;--gold-light:rgba(201,169,110,0.12);
  --forest:#4A7C59;--white:#fff;--text:#2D2D2D;--muted:#6B6B6B;
  --radius:10px;
}
html{scroll-behavior:smooth;}
body{font-family:'Noto Sans KR',sans-serif;color:var(--text);background:var(--white);overflow-x:hidden;}

/* Plan badge */
.plan-badge{position:fixed;top:16px;right:16px;z-index:999;background:var(--gold);color:var(--charcoal);padding:8px 16px;border-radius:4px;font-size:0.76rem;font-weight:700;box-shadow:0 4px 16px rgba(0,0,0,0.2);}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:300;background:rgba(28,28,28,0.97);backdrop-filter:blur(16px);box-shadow:0 1px 0 rgba(201,169,110,0.12);}
.nav-inner{max-width:1240px;margin:0 auto;height:70px;display:flex;align-items:center;justify-content:space-between;padding:0 5%;}
.logo{display:flex;align-items:center;gap:12px;text-decoration:none;}
.logo-c{width:38px;height:38px;border:1.5px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Noto Serif KR',serif;font-size:14px;color:var(--gold);}
.logo-t{font-family:'Noto Serif KR',serif;font-size:1rem;font-weight:700;color:var(--white);}
.logo-s{font-size:0.6rem;color:rgba(201,169,110,0.65);display:block;margin-top:1px;}
.nav-links{display:flex;align-items:center;gap:28px;list-style:none;}
.nav-links a{text-decoration:none;color:rgba(255,255,255,0.65);font-size:0.82rem;transition:color 0.2s;}
.nav-links a:hover{color:var(--gold);}
.nav-cta{border:1px solid var(--gold)!important;color:var(--gold)!important;padding:8px 20px;border-radius:3px;font-weight:600!important;}

/* Section commons */
.section{padding:110px 5%;}
.section-inner{max-width:1240px;margin:0 auto;}
.s-eye{display:flex;align-items:center;gap:10px;margin-bottom:18px;}
.s-eye-line{width:22px;height:1px;background:var(--gold);}
.s-eye-text{color:var(--gold);font-size:0.68rem;letter-spacing:2.5px;text-transform:uppercase;}
.s-title{font-family:'Noto Serif KR',serif;font-size:2.3rem;font-weight:700;color:var(--charcoal);margin-bottom:14px;line-height:1.35;}
.s-title em{color:var(--gold);font-style:normal;}
.s-desc{color:var(--muted);font-size:0.95rem;line-height:2;max-width:560px;}
.btn-gold{background:var(--gold);color:var(--charcoal);padding:15px 36px;border-radius:3px;font-weight:700;font-size:0.9rem;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:background 0.2s;}
.btn-gold:hover{background:var(--gold-deep);}
.btn-outline{border:1px solid rgba(201,169,110,0.5);color:var(--gold);padding:15px 36px;border-radius:3px;font-size:0.9rem;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:border-color 0.2s;}
.btn-outline:hover{border-color:var(--gold);}
.btns{display:flex;gap:12px;flex-wrap:wrap;}

/* ─── S1: HERO ─────────────────────── */
.hero{min-height:100vh;background:var(--charcoal);display:flex;align-items:center;position:relative;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background:url('/public/img/great-master.webp') center 20%/cover;opacity:0.26;filter:grayscale(18%);}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(110deg,rgba(28,28,28,0.93) 50%,rgba(28,28,28,0.55));}
.hero-inner{position:relative;z-index:2;max-width:1240px;margin:0 auto;padding:140px 5% 100px;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
.hero-tag{display:flex;align-items:center;gap:10px;margin-bottom:28px;}
.hero-tag-line{width:28px;height:1px;background:var(--gold);}
.hero-tag-text{color:var(--gold);font-size:0.7rem;letter-spacing:2.5px;text-transform:uppercase;}
.hero h1{font-family:'Noto Serif KR',serif;font-size:3.1rem;color:var(--white);line-height:1.42;margin-bottom:24px;}
.hero h1 em{color:var(--gold);font-style:normal;}
.hero-div{width:44px;height:2px;background:var(--gold);margin:24px 0;}
.hero-quote{font-family:'Noto Serif KR',serif;color:rgba(255,255,255,0.62);font-size:0.97rem;line-height:2.1;margin-bottom:40px;font-style:italic;}
.hero-lineage{display:flex;align-items:center;gap:10px;margin-top:28px;opacity:0.55;}
.hero-lineage span{font-size:0.7rem;color:rgba(201,169,110,0.8);letter-spacing:0.5px;}
.hero-lineage .arr{color:rgba(201,169,110,0.4);}
/* hero right: portrait */
.hero-right{position:relative;}
.hero-frame{width:100%;max-width:360px;margin:0 auto;aspect-ratio:3/4;position:relative;}
.hero-frame-img{width:100%;height:100%;background:url('/public/img/great-master.webp') center/cover;border-radius:4px;filter:brightness(0.78);}
.hero-frame-over{position:absolute;inset:0;border-radius:4px;background:linear-gradient(to top,rgba(28,28,28,0.65),transparent 50%);}
.hero-frame-cap{position:absolute;bottom:20px;left:20px;right:20px;}
.hero-frame-name{font-family:'Noto Serif KR',serif;font-size:1.2rem;font-weight:700;color:var(--white);}
.hero-frame-role{color:var(--gold);font-size:0.7rem;letter-spacing:1.2px;margin-top:3px;}
.hero-frame-badge{position:absolute;top:-14px;right:-14px;background:var(--gold);color:var(--charcoal);padding:12px 16px;border-radius:4px;text-align:center;}
.hero-frame-badge strong{font-family:'Noto Serif KR',serif;font-size:1.2rem;font-weight:700;display:block;}
.hero-frame-badge span{font-size:0.6rem;display:block;margin-top:1px;}
/* successor */
.hero-successor{display:flex;align-items:center;gap:12px;margin-top:16px;background:rgba(28,28,28,0.7);border:1px solid rgba(201,169,110,0.25);border-radius:6px;padding:10px 14px;}
.hero-succ-img{width:44px;height:44px;border-radius:50%;background:url('/public/img/mugyeon-master.webp') center/cover;border:2px solid var(--gold);flex-shrink:0;}
.hero-succ-label{font-size:0.6rem;color:rgba(201,169,110,0.7);letter-spacing:1px;text-transform:uppercase;margin-bottom:2px;}
.hero-succ-name{font-family:'Noto Serif KR',serif;font-size:0.84rem;font-weight:700;color:var(--white);}
.hero-succ-arrow{margin-left:auto;color:rgba(201,169,110,0.5);font-size:0.7rem;white-space:nowrap;}
/* scroll */
.hero-scroll{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);text-align:center;color:rgba(255,255,255,0.35);font-size:0.65rem;letter-spacing:2px;}
.hero-scroll-bar{width:1px;height:40px;background:linear-gradient(to bottom,var(--gold),transparent);margin:8px auto 0;animation:sp 2s ease-in-out infinite;}
@keyframes sp{0%,100%{opacity:0.4}50%{opacity:1}}

/* ─── S2: 법통 스트립 ────────────────── */
.strip-section{background:var(--white);padding:72px 5%;border-top:1px solid rgba(201,169,110,0.08);}
.strip-inner{max-width:1240px;margin:0 auto;}
.strip-eye{display:flex;align-items:center;justify-content:center;gap:16px;margin-bottom:52px;}
.strip-eye-line{width:28px;height:1px;background:rgba(201,169,110,0.4);}
.strip-eye-text{color:var(--gold);font-size:0.68rem;letter-spacing:2.5px;text-transform:uppercase;}
.strip-cards{display:grid;grid-template-columns:1fr auto 1fr auto 1fr;align-items:center;}
.strip-card{text-align:center;padding:0 24px;}
.strip-portrait{width:130px;height:168px;border-radius:8px;background-size:cover;background-position:center;margin:0 auto 18px;filter:brightness(0.82);}
.sp-gm{background-image:url('/public/img/great-master.webp');}
.sp-mu{background-image:url('/public/img/mugyeon-master.webp');}
.sp-center{width:90px;height:90px;border-radius:50%;background:var(--gold-light);border:2px solid rgba(201,169,110,0.28);margin:0 auto 18px;display:flex;align-items:center;justify-content:center;font-family:'Noto Serif KR',serif;font-size:1.8rem;color:var(--gold);}
.strip-card-lbl{font-size:0.62rem;color:var(--gold);letter-spacing:2px;text-transform:uppercase;font-weight:700;margin-bottom:8px;}
.strip-card-name{font-family:'Noto Serif KR',serif;font-size:1.05rem;font-weight:700;color:var(--charcoal);margin-bottom:4px;}
.strip-card-desc{font-size:0.78rem;color:var(--muted);line-height:1.7;}
.strip-arrow{display:flex;flex-direction:column;align-items:center;gap:8px;padding:0 10px;}
.sa-line{width:56px;height:1px;background:linear-gradient(to right,rgba(201,169,110,0.15),var(--gold),rgba(201,169,110,0.15));}
.sa-arr{color:var(--gold);font-size:1rem;}
.sa-txt{font-size:0.6rem;color:rgba(201,169,110,0.6);white-space:nowrap;}

/* ─── S3: 왜 한울인가 ─────────────────── */
.why-section{background:var(--cream);}
.why-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;margin-top:56px;}
.why-card{background:var(--white);border-radius:var(--radius);padding:36px 28px;border:1px solid rgba(201,169,110,0.1);transition:transform 0.25s,box-shadow 0.25s;}
.why-card:hover{transform:translateY(-5px);box-shadow:0 12px 36px rgba(0,0,0,0.07);}
.why-num{font-family:'Noto Serif KR',serif;font-size:2.8rem;color:rgba(201,169,110,0.2);font-weight:700;margin-bottom:12px;line-height:1;}
.why-card h3{font-family:'Noto Serif KR',serif;font-size:1.1rem;font-weight:700;color:var(--charcoal);margin-bottom:10px;}
.why-card p{color:var(--muted);font-size:0.86rem;line-height:1.9;}
.why-card .why-cta{display:inline-block;color:var(--gold);font-size:0.8rem;margin-top:16px;text-decoration:none;font-weight:600;}

/* ─── S4: 수련 과정 타임라인 ─────────── */
.timeline-section{background:var(--white);}
.tl-wrap{margin-top:60px;}
.tl-track{display:grid;grid-template-columns:repeat(8,1fr);gap:0;position:relative;}
.tl-track::before{content:'';position:absolute;top:29px;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent);}
.tl-step{text-align:center;padding:0 6px;cursor:pointer;}
.tl-dot{width:18px;height:18px;border-radius:50%;border:2px solid rgba(201,169,110,0.3);background:var(--white);margin:20px auto 16px;position:relative;z-index:1;transition:all 0.3s;}
.tl-step.active .tl-dot,.tl-step:hover .tl-dot{background:var(--gold);border-color:var(--gold);box-shadow:0 0 0 5px rgba(201,169,110,0.12);}
.tl-num{font-size:0.62rem;color:var(--gold);font-weight:700;margin-bottom:6px;opacity:0.7;}
.tl-step.active .tl-num{opacity:1;}
.tl-name{font-family:'Noto Serif KR',serif;font-size:0.76rem;font-weight:700;color:var(--charcoal-mid);line-height:1.5;}
.tl-detail{background:var(--cream);border-radius:var(--radius);padding:40px 44px;margin-top:44px;border:1px solid rgba(201,169,110,0.12);display:grid;grid-template-columns:1fr 2fr;gap:40px;align-items:center;}
.tl-detail-num{font-family:'Noto Serif KR',serif;font-size:4rem;font-weight:700;color:rgba(201,169,110,0.18);line-height:1;}
.tl-tag{display:inline-block;background:var(--gold-light);color:var(--gold);padding:3px 12px;border-radius:2px;font-size:0.66rem;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;margin-bottom:10px;}
.tl-title{font-family:'Noto Serif KR',serif;font-size:1.28rem;font-weight:700;color:var(--charcoal);margin-bottom:10px;}
.tl-desc{color:var(--muted);font-size:0.88rem;line-height:1.95;}
.tl-cta-wrap{text-align:center;margin-top:36px;}

/* ─── S5: 한울예술 ───────────────────── */
.arts-section{background:var(--cream);}
.arts-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:18px;margin-top:56px;}
.art-card{background:var(--white);border-radius:var(--radius);padding:30px 18px;text-align:center;border:1px solid rgba(201,169,110,0.1);transition:transform 0.25s,box-shadow 0.25s;}
.art-card:hover{transform:translateY(-5px);box-shadow:0 12px 36px rgba(0,0,0,0.07);border-color:rgba(201,169,110,0.35);}
.art-icon{width:56px;height:56px;border-radius:50%;background:var(--gold-light);border:1px solid rgba(201,169,110,0.2);margin:0 auto 18px;display:flex;align-items:center;justify-content:center;font-size:20px;}
.art-card .art-tag{font-size:0.62rem;color:var(--gold);letter-spacing:1px;text-transform:uppercase;font-weight:700;margin-bottom:10px;}
.art-card h4{font-family:'Noto Serif KR',serif;font-size:0.95rem;font-weight:700;color:var(--charcoal);margin-bottom:8px;}
.art-card p{color:var(--muted);font-size:0.78rem;line-height:1.85;}

/* ─── S6: 오늘의 법문 ────────────────── */
.lawmun-section{background:var(--charcoal);padding:112px 5%;overflow:hidden;}
.lawmun-inner{max-width:960px;margin:0 auto;text-align:center;}
.law-eye{color:var(--gold);font-size:0.68rem;letter-spacing:3px;margin-bottom:36px;display:flex;align-items:center;justify-content:center;gap:16px;}
.law-eye::before,.law-eye::after{content:'';width:40px;height:1px;background:rgba(201,169,110,0.3);}
/* 탭 UI */
.law-tabs{display:flex;justify-content:center;gap:0;margin-bottom:44px;border:1px solid rgba(201,169,110,0.2);border-radius:6px;overflow:hidden;max-width:480px;margin-left:auto;margin-right:auto;}
.law-tab{flex:1;padding:12px 20px;font-size:0.82rem;font-weight:700;cursor:pointer;border:none;background:transparent;color:rgba(201,169,110,0.5);letter-spacing:0.5px;transition:all 0.25s;font-family:inherit;}
.law-tab.active{background:rgba(201,169,110,0.12);color:var(--gold);border-bottom:2px solid var(--gold);}
.law-tab-count{font-size:0.68rem;color:rgba(201,169,110,0.4);margin-left:6px;}
.law-tab.active .law-tab-count{color:rgba(201,169,110,0.7);}
.law-panel{display:none;}.law-panel.active{display:block;}
.law-slides{position:relative;min-height:200px;}
.law-slide{position:absolute;inset:0;opacity:0;transform:translateY(14px);transition:opacity 0.8s,transform 0.8s;display:flex;flex-direction:column;justify-content:center;}
.law-slide.active{opacity:1;transform:translateY(0);}
.law-mark{font-family:'Noto Serif KR',serif;font-size:4.5rem;color:rgba(201,169,110,0.18);line-height:0.8;margin-bottom:14px;display:block;}
.law-text{font-family:'Noto Serif KR',serif;font-size:1.5rem;color:rgba(255,255,255,0.86);line-height:1.9;letter-spacing:-0.2px;}
.law-src{margin-top:28px;color:rgba(201,169,110,0.6);font-size:0.76rem;}
.law-dots{display:flex;justify-content:center;gap:8px;margin-top:52px;}
.law-dot{width:5px;height:5px;border-radius:50%;background:rgba(201,169,110,0.22);cursor:pointer;border:none;transition:all 0.3s;}
.law-dot.active{background:var(--gold);transform:scale(1.35);}
.law-progress{width:100%;height:1px;background:rgba(201,169,110,0.08);margin-top:24px;overflow:hidden;position:relative;}
.law-bar{position:absolute;left:0;top:0;height:100%;background:var(--gold);width:0;transition:width 0.1s linear;}
.law-cta-row{margin-top:44px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}

/* ─── S7: 참가자 후기 ────────────────── */
.reviews-section{background:var(--white);}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:56px;}
.review-card{background:var(--cream);border-radius:var(--radius);padding:32px 28px;border:1px solid rgba(201,169,110,0.1);}
.review-stars{color:var(--gold);font-size:0.85rem;margin-bottom:14px;letter-spacing:2px;}
.review-text{font-family:'Noto Serif KR',serif;font-size:0.92rem;color:var(--charcoal);line-height:1.95;margin-bottom:20px;font-style:italic;}
.review-author{display:flex;align-items:center;gap:12px;}
.review-avatar{width:38px;height:38px;border-radius:50%;background:var(--gold-light);border:1.5px solid rgba(201,169,110,0.25);display:flex;align-items:center;justify-content:center;font-size:16px;}
.review-name{font-size:0.82rem;font-weight:700;color:var(--charcoal);}
.review-meta{font-size:0.72rem;color:var(--muted);}
.reviews-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:0;margin-top:48px;background:var(--charcoal);border-radius:var(--radius);overflow:hidden;}
.r-stat{padding:32px;text-align:center;border-right:1px solid rgba(255,255,255,0.05);}
.r-stat:last-child{border-right:none;}
.r-stat-num{font-family:'Noto Serif KR',serif;font-size:2.2rem;color:var(--gold);font-weight:700;}
.r-stat-lbl{color:rgba(255,255,255,0.4);font-size:0.78rem;margin-top:6px;line-height:1.6;}

/* ─── S8: 수련 일정 ─────────────────── */
.sch-section{background:var(--cream);}
.sch-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-top:56px;}
.sch-cards{display:flex;flex-direction:column;gap:14px;}
.sch-card{background:var(--white);border-radius:8px;padding:18px 20px;border:1px solid rgba(201,169,110,0.1);display:flex;gap:16px;align-items:flex-start;}
.sch-date{min-width:48px;background:var(--charcoal);border-radius:6px;padding:8px;text-align:center;}
.sch-month{color:var(--gold);font-size:0.58rem;font-weight:700;letter-spacing:1px;}
.sch-day{color:var(--white);font-family:'Noto Serif KR',serif;font-size:1.4rem;font-weight:700;line-height:1.1;}
.sch-info h4{font-family:'Noto Serif KR',serif;font-size:0.95rem;font-weight:700;color:var(--charcoal);margin-bottom:3px;}
.sch-info p{color:var(--muted);font-size:0.8rem;line-height:1.7;}
.sch-badge{display:inline-block;font-size:0.6rem;font-weight:700;padding:2px 8px;border-radius:2px;margin-bottom:5px;letter-spacing:0.8px;}
.sch-open{background:rgba(74,124,89,0.12);color:var(--forest);}
.sch-soon{background:rgba(201,169,110,0.12);color:var(--gold);}
.sch-panel{background:var(--charcoal);border-radius:var(--radius);padding:34px 28px;display:flex;flex-direction:column;gap:22px;}
.sch-stat{border-bottom:1px solid rgba(255,255,255,0.05);padding-bottom:18px;}
.sch-stat:last-of-type{border-bottom:none;}
.sch-stat-n{font-family:'Noto Serif KR',serif;font-size:2.2rem;color:var(--gold);font-weight:700;}
.sch-stat-l{color:rgba(255,255,255,0.4);font-size:0.78rem;margin-top:4px;line-height:1.6;}

/* ─── S9: 갤러리 ────────────────────── */
.gallery-section{background:var(--charcoal);padding:110px 5%;}
.gallery-section .s-title{color:var(--white);}
.gallery-section .s-eye-text,.gallery-section .s-eye-line{color:var(--gold);background:var(--gold);}
.gallery-section .s-desc{color:rgba(255,255,255,0.45);}
.gal-grid{display:grid;grid-template-columns:2fr 1fr 1fr;grid-template-rows:240px 240px;gap:10px;margin-top:52px;}
.gal-item{border-radius:8px;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;font-size:26px;position:relative;overflow:hidden;cursor:pointer;transition:transform 0.2s;}
.gal-item:hover{transform:scale(1.02);}
.gal-item.large{grid-row:span 2;}
.gal-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(28,28,28,0.6),transparent);opacity:0;transition:opacity 0.3s;}
.gal-item:hover .gal-overlay{opacity:1;}
.gal-label{position:absolute;bottom:14px;left:14px;right:14px;opacity:0;transform:translateY(8px);transition:all 0.3s;color:var(--white);font-size:0.82rem;font-weight:600;}
.gal-item:hover .gal-label{opacity:1;transform:translateY(0);}
.gal-cta{text-align:center;margin-top:36px;}

/* ─── CTA ─────────────────────────── */
.cta-section{background:var(--charcoal);padding:120px 5%;text-align:center;position:relative;overflow:hidden;}
.cta-section::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(201,169,110,0.06),transparent 65%);}
.cta-inner{position:relative;z-index:1;max-width:660px;margin:0 auto;}
.cta-inner h2{font-family:'Noto Serif KR',serif;font-size:2.5rem;color:var(--white);line-height:1.45;margin-bottom:18px;}
.cta-inner h2 em{color:var(--gold);font-style:normal;}
