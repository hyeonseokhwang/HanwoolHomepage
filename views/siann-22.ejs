<!-- Chatbot & Archive: hanul-components.js 가 자동 삽입 -->

<script>
// Timeline
const tlSteps = [{tag:'기초',title:'수련 프로그램',desc:'건강과 삶의 행복을 위한 입문자 과정. 한울사상의 기초를 체험하며 수도의 첫 발걸음을 내딛습니다.'},{tag:'기초',title:'입문과정 1·2',desc:'3개월 단계별 입문 과정. 한울사상의 철학과 수행 방법을 체계적으로 익힙니다.'},{tag:'기초',title:'기초 회로 과정',desc:'입문과정 이수 후 수행의 기초 회로를 확립하고 내면의 흐름을 감지합니다.'},{tag:'중급',title:'특별수련 프로그램',desc:'정화 프로그램과 지기문화답사 참여를 통한 심화 체험 수련입니다.'},{tag:'중급',title:'월제도 프로그램',desc:'재가 수련 회원을 위한 매월 제도 보조 과정. 일상 속 수행을 지속합니다.'},{tag:'심화',title:'생명장 조정 프로그램',desc:'몸氣·地氣·영氣를 조정하는 특수 수련. 생명 에너지 정렬을 목적으로 합니다.'},{tag:'심화',title:'여의수도 프로그램',desc:'영적진화를 목적으로 하는 심화 수도 과정. 근원과의 합일을 향한 여정입니다.'},{tag:'최심화',title:'우주○제도 프로그램',desc:'우주○초대와 우주영제도에 참여하는 최심화 과정. 수도의 정점에 이릅니다.'}];
const stepEls = document.querySelectorAll('.tl-step');
function showStep(i){stepEls.forEach((el,j)=>el.classList.toggle('active',j===i));const s=tlSteps[i];document.getElementById('tlNum').textContent=String(i+1).padStart(2,'0');document.getElementById('tlTag').textContent=s.tag;document.getElementById('tlTitle').textContent=s.title;document.getElementById('tlDesc').textContent=s.desc;}
stepEls.forEach(el=>el.addEventListener('click',()=>showStep(+el.dataset.idx)));
// 법문 탭 전환
document.querySelectorAll('.law-tab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    document.querySelectorAll('.law-tab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.law-panel').forEach(p=>p.classList.remove('active'));
    tab.classList.add('active');
    const t=tab.dataset.tab;
    document.getElementById(t==='gm'?'panelGm':'panelMu').classList.add('active');
    if(t==='gm'&&!sliderGm.aId){sliderGm.start();}
    if(t==='mu'&&!sliderMu.aId){sliderMu.start();}
  });
});
// 슬라이더 팩토리
function makeSlider(slidesId,dotsId,barId){
  const slides=document.querySelectorAll('#'+slidesId+' .law-slide');
  const dots=document.querySelectorAll('#'+dotsId+' .law-dot');
  const bar=document.getElementById(barId);
  let cur=0,st=Date.now(),aId=null;
  const IV=6000;
  function show(i){slides[cur].classList.remove('active');dots[cur].classList.remove('active');cur=i;slides[cur].classList.add('active');dots[cur].classList.add('active');st=Date.now();if(bar)bar.style.width='0%';}
  function tick(){const e=Date.now()-st;if(bar)bar.style.width=Math.min(e/IV*100,100)+'%';if(e>=IV)show((cur+1)%slides.length);aId=requestAnimationFrame(tick);}
  function start(){aId=requestAnimationFrame(tick);}
  dots.forEach(d=>d.addEventListener('click',()=>{cancelAnimationFrame(aId);show(+d.dataset.idx);aId=requestAnimationFrame(tick);}));
  return{start,get aId(){return aId}};
}
const sliderGm=makeSlider('lawSlidesGm','lawDotsGm','lawBarGm');
const sliderMu=makeSlider('lawSlidesMu','lawDotsMu','lawBarMu');
sliderGm.start();sliderMu.start();
</script>
<script src="/js/hanul-components.js"></script>
